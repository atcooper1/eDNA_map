<html lang="en">
<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>eDNA Map</title>

  <script src="https://api.mapbox.com/mapbox-gl-js/v3.14.0/mapbox-gl.js"></script>
  <link href="https://api.mapbox.com/mapbox-gl-js/v3.14.0/mapbox-gl.css" rel="stylesheet" />

  <style>
    body { margin: 0; padding: 0; }
    #map { width: 100%; height: 100vh; }
  </style>
</head>

<body>
<div id="map"></div>

<script>

mapboxgl.accessToken = 'YOUR_TOKEN';

const map = new mapboxgl.Map({
  container: 'map',
  style: 'mapbox://styles/tonecoops/cmoql5fhd006q01rg3fye1xgm',
  center: [147, -40],
  zoom: 4
});

map.on('load', () => {

  // 🔹 Load your GeoJSON
  fetch('eDNA_sites_may_update.geojson')
    .then(res => res.json())
    .then(data => {

      map.addSource('sites', {
        type: 'geojson',
        data: data
      });

      // 🔹 Add pins (circles for now)
      map.addLayer({
        id: 'sites-layer',
        type: 'circle',
        source: 'sites',
        paint: {
          'circle-radius': 6,
          'circle-color': [
            'match',
            ['get', 'protection status'],
            'No take multizoned', '#2ecc71',
            'Restricted take multizoned', '#f39c12',
            'Fishing', '#e74c3c',
            '#999999'
          ]
        }
      });

      // 🔹 Popups
      map.on('click', 'sites-layer', (e) => {
        const props = e.features[0].properties;

        new mapboxgl.Popup()
          .setLngLat(e.lngLat)
          .setHTML(`
            <h3>${props.site_name}</h3>
            <p><b>Site Code:</b> ${props.site_code}</p>
            <p><b>Marine Park:</b> ${props.mpa}</p>
            <p><b>Protection:</b> ${props.protection_status}</p>
            <p><b>Latitude:</b> ${props.latitude}</p>
            <p><b>Longitude:</b> ${props.longitude}</p>
            <p><b>depth:</b> ${props.depth}</p>
          `)
          .addTo(map);
      });

      // 🔹 Cursor change
      map.on('mouseenter', 'sites-layer', () => {
        map.getCanvas().style.cursor = 'pointer';
      });

      map.on('mouseleave', 'sites-layer', () => {
        map.getCanvas().style.cursor = '';
      });

    });

});

</script>
</body>
</html>
